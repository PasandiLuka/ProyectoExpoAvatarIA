{"nodes": [{"id": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "label": "Explicit [Parameter] Data Flow Instead of @inject AvatorState", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Blazor solo re-renderiza componentes hijos cuando sus [Parameter] cambian (optimizaci\u00f3n ShouldRender). Al leer AvatarState v\u00eda @inject, los cambios de personalizaci\u00f3n nunca disparan re-render porque los par\u00e1metros cinem\u00e1ticos no cambian. Soluci\u00f3n: AvatarRenderer lee TODO de AvatarState y pasa valores como [Parameter] a hijos, estableciendo flujo unidireccional can\u00f3nico de Blazor."}, {"id": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_scale_2x", "label": "Avatar Scale 2\u00d7 via CSS transform", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agregar scale(2) al final de la cadena de transform existente en TorsoTransform con transform-origin: center bottom. El avatar ocupa solo ~15% del panel central (180px en panel de ~1152px). Escalar 2\u00d7 lo lleva a 360\u00d7500px visuales, ocupaci\u00f3n adecuada. Alternativa de reescribir todos los px en CSS (~30 valores) es fr\u00e1gil."}, {"id": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_arm_color_css", "label": "Arm Upper Segment Color via CSS Sibling Selectors", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Eliminar background: inherit del markup de arm-upper. Usar CSS con selector de hermano general ~: .arm-upper { background-color: var(--skin-color) } por defecto; .torso.shirt-long ~ .arm-container .arm-upper { background-color: #2b2d42 } para manga larga. Evita dependencia fr\u00e1gil de herencia."}], "edges": [{"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "target": "avatar_customization_spec_modified_parameter_flow", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "target": "avatar_rendering_spec_modified_explicit_parameters", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "target": "avatar_rendering_spec_added_unidirectional_flow", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_scale_2x", "target": "avatar_rendering_spec_modified_explicit_parameters", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_arm_color_css", "target": "avatar_rendering_spec_modified_explicit_parameters", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "target": "2026_06_04_build_avatar_tracking_system_design_avatarstate_singleton", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_scale_2x", "target": "2026_06_04_build_avatar_tracking_system_design_css_3d_torso", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "fix_customization_rendering_triad", "label": "Fix-Customization Rendering Improvements Triad", "nodes": ["2026_06_04_fix_customization_render_and_arm_avatar_scale_design_parameter_data_flow", "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_scale_2x", "2026_06_04_fix_customization_render_and_arm_avatar_scale_design_arm_color_css"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-customization-render-and-arm-avatar-scale/design.md"}]}