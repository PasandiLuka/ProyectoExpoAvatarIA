{"nodes": [{"id": "informacion_fase3_grid_layout", "label": "3-Column CSS Grid Layout (20%/60%/20%)", "file_type": "document", "source_file": "Informacion/Fase 3_ Componentes y CSS.txt", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "informacion_fase3_avatar_state", "label": "AvatarState Singleton Service (StateContainer)", "file_type": "code", "source_file": "Informacion/Fase 3_ Componentes y CSS.txt", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "informacion_fase3_arm_rigidity_css", "label": "Arm Rigidity CSS Rules (Fixed Size, Transform-Origin Anchoring)", "file_type": "rationale", "source_file": "Informacion/Fase 3_ Componentes y CSS.txt", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Arms use position:absolute and transform-origin:top center for rigid permanent anchoring to shoulder joints. Fixed size prevents deformation from camera errors. Neutral state = rotate(0deg), arms hanging vertically."}, {"id": "informacion_fase3_perspective_3d", "label": "CSS 3D Perspective (800px) for Torso", "file_type": "rationale", "source_file": "Informacion/Fase 3_ Componentes y CSS.txt", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Center panel has perspective:800px to enable depth space for torso rotation. Body-wrapper applies rotateY based on computed shoulder depth difference, giving immersion without a 3D engine."}], "edges": [{"source": "informacion_fase3_grid_layout", "target": "informacion_proto_avatar_css_system", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Informacion/Fase 3_ Componentes y CSS.txt", "source_location": null, "weight": 1.0}], "hyperedges": []}