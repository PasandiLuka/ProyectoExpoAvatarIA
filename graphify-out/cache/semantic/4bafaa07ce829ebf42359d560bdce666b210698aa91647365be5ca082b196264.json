{"nodes": [{"id": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_indentation_bug", "label": "Server.py continue Indentation Bug Fix", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Un continue mal indentado en server.py descarta todos los mensajes binarios \u2014 solo los mensajes de texto (ping) son procesados. Corregido el indent, el servidor procesa frames correctamente. Causa ra\u00edz del tracking no funcional a pesar de c\u00e1mara conectada."}, {"id": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_skeleton_overlay", "label": "Real-Time Skeleton Overlay on Camera View", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MediaPipe ya detecta los 33 landmarks de pose. Para feedback visual se necesita enviar todos los landmarks y dibujar l\u00edneas de conexi\u00f3n. Usar canvas overlay (no SVG/DOM) para dibujo eficiente sin crear/eliminar elementos DOM en cada frame. Conexiones del esqueleto son fijas (topolog\u00eda MediaPipe Pose)."}, {"id": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_canvas_overlay", "label": "Canvas Overlay Approach Instead of SVG/DOM", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Un canvas permite dibujar l\u00edneas y puntos eficientemente sin crear/eliminar elementos DOM en cada frame. El canvas se posiciona con position: absolute sobre el <video> de la c\u00e1mara. Dibujar 33 puntos + ~11 l\u00edneas por frame es operaci\u00f3n trivial (<1ms)."}, {"id": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_normalized_landmarks", "label": "Normalized Landmark Coordinates Protocol (0-1)", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "El servidor env\u00eda landmarks normalizados. El cliente convierte a p\u00edxeles usando las dimensiones del canvas. Esto mantiene el protocolo independiente de resoluci\u00f3n. El campo skeleton incluye width/height del frame original para la conversi\u00f3n."}], "edges": [{"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_indentation_bug", "target": "websocket_tracking_spec_modified_binary_processing", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_skeleton_overlay", "target": "skeleton_overlay_spec_capability", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_normalized_landmarks", "target": "skeleton_overlay_spec_capability", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_canvas_overlay", "target": "skeleton_overlay_spec_capability", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_skeleton_overlay", "target": "websocket_tracking_spec_modified_binary_processing", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_04_fix_tracking_and_add_skeleton_overlay_design_skeleton_overlay", "target": "camera_capture_spec_capability", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "openspec/changes/archive/2026-06-04-fix-tracking-and-add-skeleton-overlay/design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}