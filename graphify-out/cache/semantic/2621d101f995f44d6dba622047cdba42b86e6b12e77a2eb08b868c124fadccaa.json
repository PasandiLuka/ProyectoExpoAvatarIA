{"nodes": [{"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design", "label": "Responsive Avatar and Dynamic WS \u2014 Design", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design_overflow_hidden_containment", "label": "overflow:hidden on panel-central for avatar containment", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Simplest way to clip avatar overflow when arms/head extend beyond panel bounds. Symmetric clipping since avatar is centered. Mitigated by 0.85 safety factor."}, {"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design_dynamic_scale_calculation", "label": "Dynamic avatar scale from container dimensions (Math.min(cw/180, ch/400)*0.85)", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces hardcoded scale(2) with container-responsive calculation. Uses body-wrapper base width 180px and estimated avatar height 400px. 0.85 safety factor prevents edge contact. Recalculated each update() frame for window resize adaptation."}, {"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design_websocket_url_baseaddress", "label": "WebSocket URL derived from HostEnvironment.BaseAddress", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces hardcoded ws://localhost:8765 with dynamic derivation from HTTP host. Enables other devices on network to connect. Avoids JS interop since BaseAddress already contains the host. Risk: ws:// may fail with HTTPS (mixed content)."}, {"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design_body_wrapper_base_dimensions", "label": "body-wrapper base dimensions: width 180px, total avatar height ~400px", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_05_responsive_avatar_and_dynamic_ws_design_safety_factor_085", "label": "0.85 safety factor for dynamic scale to prevent edge contact", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "2026_06_05_responsive_avatar_and_dynamic_ws_design_overflow_hidden_containment", "target": "2026_06_05_responsive_avatar_and_dynamic_ws_design_dynamic_scale_calculation", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_05_responsive_avatar_and_dynamic_ws_design_dynamic_scale_calculation", "target": "2026_06_05_responsive_avatar_and_dynamic_ws_design_safety_factor_085", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-05-responsive-avatar-and-dynamic-ws/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_05_responsive_avatar_and_dynamic_ws_design_dynamic_scale_calculation", "target": "2026_06_05_responsive_avatar_and_dynamic_ws_design_body_wrapper_base_dimensions", "relat