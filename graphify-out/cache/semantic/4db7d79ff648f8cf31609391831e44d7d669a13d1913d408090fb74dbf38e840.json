{"nodes": [{"id": "2026_06_05_stay_upright_hand_items_design", "label": "Stay Upright Hand Items \u2014 Design", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_05_stay_upright_hand_items_design_rotation_compensation", "label": "JS rotation compensation (baseRotation - shoulderAngle - elbowAngle)", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CSS cannot read tracking angles (JS-only), so compensation runs in avatarAnim.update(). Subtracts accumulated shoulder+elbow angles to cancel inherited rotation, then applies \u00b190\u00b0 base for outward orientation. Sign errors would cause double rotation instead of cancellation."}, {"id": "2026_06_05_stay_upright_hand_items_design_stay_upright_css_optin", "label": "stay-upright CSS class as opt-in for upright hand items", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Instead of Blazor boolean parameter, uses hardcoded CSS class. Items with stay-upright (fernet, water, cup) get compensation; items without (future watch, bracelet) follow arm rotation naturally. Simpler than adding per-item Blazor parameters."}, {"id": "2026_06_05_stay_upright_hand_items_design_queryselector_loop_per_frame", "label": "querySelectorAll('.item.stay-upright.active') per-frame loop", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "DOM query each update() frame to find active upright items. ~0.1ms for 3 elements, negligible performance impact. Uses closest('.arm-container.left') to determine handedness for sign direction."}, {"id": "2026_06_05_stay_upright_hand_items_design_arm_container_handedness_detection", "label": "Arm container handedness detection via closest('.arm-container.left')", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "2026_06_05_stay_upright_hand_items_design_rotation_compensation", "target": "2026_06_05_stay_upright_hand_items_design_stay_upright_css_optin", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_05_stay_upright_hand_items_design_rotation_compensation", "target": "2026_06_05_stay_upright_hand_items_design_arm_container_handedness_detection", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "weight": 1.0}, {"source": "2026_06_05_stay_upright_hand_items_design_rotation_compensation", "target": "2026_06_05_stay_upright_hand_items_design_queryselector_loop_per_frame", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-05-stay-upright-hand-items/design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}