{"nodes": [{"id": "2026_06_05_manual_avatar_scale_slider_design", "label": "Manual Avatar Scale Slider \u2014 Design", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-05-manual-avatar-scale-slider/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_06_05_manual_avatar_scale_slider_design_manualscale_null_override", "label": "manualScale null-override pattern (null=auto, number=manual)", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-manual-avatar-scale-slider/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Simple boolean-free state: null means auto mode (dynamic calculation), any number means manual override. Avoids complex state machines."}, {"id": "2026_06_05_manual_avatar_scale_slider_design_hamburger_menu_collapse", "label": "Hamburger menu collapse pattern for scale slider UI", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-manual-avatar-scale-slider/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Slider menu hid behind hamburger toggle button using CSS max-height+overflow:hidden for animated collapse without JS. Does not occupy permanent space when unused."}, {"id": "2026_06_05_manual_avatar_scale_slider_design_js_interop_direct_slider", "label": "Direct JS interop for slider (C# to JS, bypassing Blazor state)", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-05-manual-avatar-scale-slider/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Slider calls JS.InvokeVoidAsync('avatarAnim.setManualScale') directly instead of routing through AvatarState C#\u2192Blazor\u2192JS. Avoids unnecessary cycle; ~0.1ms per call at 60fps is negligible."},